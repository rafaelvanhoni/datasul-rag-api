# Copie este arquivo para .env e preencha com os seus valores.
# O .env está no .gitignore — nunca versione credenciais.

# Servidor Ollama (IP Tailscale ou localhost)
OLLAMA_BASE_URL=http://localhost:11434

# String de conexão assíncrona usada pela aplicação (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://user:change_me@localhost:5432/datasul_rag

# Usadas pelo docker-compose ao criar o container do PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me
